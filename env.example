# Configurações do Banco de Dados PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sistema_vendas
DB_USER=postgres
DB_PASSWORD=sua_senha_aqui

# Configurações do Servidor
PORT=3000
NODE_ENV=development

# Configurações de Email (Nodemailer) - DESABILITADO PARA DESENVOLVIMENTO
EMAIL_ENABLED=false
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=seu_email@gmail.com
EMAIL_PASS=sua_senha_app
EMAIL_SECURE=false

# Configurações JWT
JWT_SECRET=sua_chave_secreta_jwt_aqui_muito_segura_123456789
JWT_EXPIRES_IN=24h

# Configurações WhatsApp (Twilio) - DESABILITADO PARA DESENVOLVIMENTO
WHATSAPP_ENABLED=false
TWILIO_ACCOUNT_SID=AC00000000000000000000000000000000
TWILIO_AUTH_TOKEN=seu_auth_token
TWILIO_PHONE_NUMBER=seu_numero_whatsapp

# Configurações de Notificações Push - DESABILITADO PARA DESENVOLVIMENTO
PUSH_ENABLED=false
VAPID_PUBLIC_KEY=seu_vapid_public_key
VAPID_PRIVATE_KEY=seu_vapid_private_key

# Configurações de Sincronização
SYNC_INTERVAL=5000

# Configurações de CORS
CORS_ORIGIN=* 