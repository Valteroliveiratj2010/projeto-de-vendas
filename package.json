{
  "name": "sistema-vendas",
  "version": "1.0.0",
  "description": "Sistema de Vendas com suporte offline (PWA)",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:setup": "node scripts/setup-database.js",
    "db:setup:prod": "NODE_ENV=production node scripts/setup-database.js",
    "db:fix": "node scripts/add-missing-columns.js",
    "db:migrate": "node scripts/migrate-database.js",
    "db:test": "node scripts/test-database.js",
    "db:test:ssl": "node scripts/test-render-ssl.js",
    "css:optimize": "node scripts/optimize-css.js",
    "validate": "node scripts/validate-config.js",
    "validate:report": "node scripts/validate-config.js --report",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "code:quality": "npm run lint && npm run format:check",
    "build": "webpack --mode=production",
    "build:dev": "webpack --mode=development",
    "build:simple": "node scripts/build-simple.js",
    "build:analyze": "webpack --mode=production --env analyze",
    "build:stats": "webpack --mode=production --json > dist/stats.json",
    "dev:webpack": "webpack serve --mode=development",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "setup": "npm run db:setup && npm run css:optimize",
    "setup:prod": "NODE_ENV=production npm run db:setup && npm run css:optimize",
    "postinstall": "npm run setup"
  },
  "keywords": [
    "vendas",
    "pwa",
    "offline",
    "postgresql"
  ],
  "author": "Sistema de Vendas",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-session": "^1.18.2",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "html-pdf-node": "^1.0.8",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.29.4",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.7",
    "pdfkit": "^0.14.0",
    "pg": "^8.11.3",
    "puppeteer": "^24.16.2",
    "socket.io": "^4.8.1",
    "twilio": "^5.8.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-proposal-object-rest-spread": "^7.20.7",
    "@babel/preset-env": "^7.24.0",
    "@types/express": "^4.17.23",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.3.0",
    "@types/supertest": "^6.0.3",
    "autoprefixer": "^10.4.18",
    "babel-jest": "^29.7.0",
    "babel-loader": "^9.1.3",
    "clean-webpack-plugin": "^4.0.0",
    "compression-webpack-plugin": "^11.1.0",
    "core-js": "^3.36.0",
    "css-loader": "^6.10.0",
    "css-minimizer-webpack-plugin": "^6.0.0",
    "cssnano": "^6.0.3",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "html-webpack-plugin": "^5.6.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "mini-css-extract-plugin": "^2.8.1",
    "morgan": "^1.10.1",
    "nodemon": "^3.0.2",
    "postcss-loader": "^8.1.0",
    "prettier": "^3.2.5",
    "style-loader": "^3.3.4",
    "supertest": "^7.1.4",
    "terser-webpack-plugin": "^5.3.10",
    "typescript": "^5.9.2",
    "webpack": "^5.90.3",
    "webpack-bundle-analyzer": "^4.10.2",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.0.2",
    "winston": "^3.17.0"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}